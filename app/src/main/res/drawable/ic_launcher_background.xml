<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon background: gold gradient sampled from the icon's own edges
  (top #FDC00C -> bottom #FDAF02). This fills the masked edge so the launcher
  shows the gold icon edge-to-edge with NO white padding ring.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="linear"
        android:angle="270"
        android:startColor="#FDC00C"
        android:endColor="#FDAF02" />
</shape>
