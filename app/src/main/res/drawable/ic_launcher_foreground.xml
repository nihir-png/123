<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon foreground: the EXACT source artwork (custom_app_icon.png).
  Inset reduced to 2% per side so the artwork fills ~96% of the canvas.
  Android's adaptive icon system already applies its own safe-zone masking,
  so this keeps the icon large and avoids excessive padding in the launcher.
-->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@drawable/custom_app_icon"
    android:insetLeft="2%"
    android:insetTop="2%"
    android:insetRight="2%"
    android:insetBottom="2%" />
