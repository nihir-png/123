<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon foreground: the EXACT source artwork (custom_app_icon.png).
  Inset ~16% per side so the WHOLE gold rounded-square + clock fits inside the
  launcher's circular/squircle mask instead of being zoomed in (which cropped
  the gold frame). The gold gradient background fills the masked corners, so
  there is NO white/empty padding ring — the icon stays gold edge-to-edge and
  looks like custom_app_icon.png.
-->
<inset xmlns:android="http://schemas.android.com/apk/res/android"
    android:drawable="@drawable/custom_app_icon"
    android:insetLeft="16%"
    android:insetTop="16%"
    android:insetRight="16%"
    android:insetBottom="16%" />
